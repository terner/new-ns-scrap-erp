model trading_deals {
  id                      String          @id
  deal_no                 String
  date                    DateTime        @db.Date
  purchase_bill_id        String?
  purchase_bill_no        String?
  sales_bill_id           String?
  sales_bill_no           String?
  product_id              String?
  supplier_id             String?
  customer_id             String?
  matched_qty             Decimal?        @default(0) @db.Decimal
  matched_purchase_amount Decimal?        @default(0) @db.Decimal
  matched_sales_amount    Decimal?        @default(0) @db.Decimal
  ex_vat                  Boolean?        @default(true)
  status                  String?         @default("Partially Matched")
  notes                   String?
  created_by              String?
  cancelled_at            DateTime?       @db.Timestamptz(6)
  created_at              DateTime?       @default(now()) @db.Timestamptz(6)
  note                    String?
  updated_at              DateTime?       @db.Timestamptz(6)
  updated_by              String?
  version                 Int?            @default(1)
  cancelled_by            String?
  cancelled_reason        String?
  auto_created            Boolean?        @default(false)
  customers               customers?      @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products                products?       @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_bills          purchase_bills? @relation(fields: [purchase_bill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_bills             sales_bills?    @relation(fields: [sales_bill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers               suppliers?      @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchase_bill_id], map: "idx_deal_pb")
  @@index([sales_bill_id], map: "idx_deal_sb")
  @@index([purchase_bill_id, sales_bill_id], map: "idx_trading_deals_bills", where: raw("(status <> 'Cancelled'::text)"))
  @@schema("public")
}

