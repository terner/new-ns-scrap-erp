# Supabase dev/target project database
# Use the dev-target Supabase project for local development.
DATABASE_URL=postgresql://postgres.fhglqymcdmrgbsbadnwr:replace-with-dev-db-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase dev/target frontend client
NEXT_PUBLIC_SUPABASE_URL=https://fhglqymcdmrgbsbadnwr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-dev-anon-key
VITE_SUPABASE_URL=https://fhglqymcdmrgbsbadnwr.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-dev-anon-key
VITE_AUTH_BYPASS=false

# Server-only Supabase admin key for invite/admin auth operations.
# Keep the real value only in local env or Vercel env. Never expose with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=replace-with-dev-service-role-key

# Supabase dev/target database connection for local DB tooling.
# Do not put real credentials in this example file.
SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.fhglqymcdmrgbsbadnwr
SUPABASE_DB_PASSWORD=replace-with-dev-db-password
SUPABASE_DB_URL=postgresql://postgres.fhglqymcdmrgbsbadnwr:replace-with-dev-db-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Local development login prefill only.
# Do not commit real passwords.
DEV_LOGIN_IDENTIFIER=replace-with-dev-login-email
DEV_LOGIN_PASSWORD=replace-with-dev-login-password

# Temporary test-login prefill for hosted demos.
# WARNING: NEXT_PUBLIC values are visible in browser output. Remove before real UAT/production use.
NEXT_PUBLIC_ENABLE_TEST_LOGIN_PREFILL=0
NEXT_PUBLIC_TEST_LOGIN_IDENTIFIER=replace-with-test-login-email
NEXT_PUBLIC_TEST_LOGIN_PASSWORD=replace-with-test-login-password
